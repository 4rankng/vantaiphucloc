# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vantaihanghoa

# Auth — SECRET_KEY MUST be changed from default in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment: development | production
# In production, the server will refuse to start if SECRET_KEY is still the default.
ENVIRONMENT=development

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Service (for container OCR). Provider order is OpenRouter → Gemini →
# Gemini on any error (e.g. HTTP 429). Enable OPENROUTER_ENABLE + GEMINI_ENABLE
# together for automatic failover, or just one to run a single provider.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY2=
GEMINI_ENABLE=true
# Docker Hub
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_PASSWORD=your-dockerhub-password
